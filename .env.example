# =============================================================================
# LOCAL — не коммитить заполненный .env
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
API_HOST=0.0.0.0

# --- Optional local ---
# GCP_PROJECT_ID=
# ENGINE_INSTANCE_ID=local-1

# =============================================================================
# SERVER-ONLY (engine / Cloud Run) — NEVER in web / NEVER in git
# =============================================================================
# BINANCE_BASE_URL=https://api.binance.com
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_CHAT_ID=

# =============================================================================
# ENGINE — LIVE OFF BY DEFAULT (обязательно false до pre-live чеклиста)
# =============================================================================
ENGINE_TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
ENGINE_POLL_INTERVAL_MS=120000
ENGINE_POLL_JITTER_FRAC=0.08
ENGINE_USER_ID=system
ENGINE_PERSISTENCE=memory
# firestore: renew < 50% lease (zod)
ENGINE_LEADER_LEASE_MS=90000
ENGINE_LEADER_RENEW_MS=30000
EMERGENCY_HALT=false
ENGINE_UNIVERSE=BTCUSDT,ETHUSDT
PAPER_EQUITY=100000
# Klines: публичный REST, ключи Binance не обязательны. Подписанные вызовы — при наличии ключей.

# =============================================================================
# STAGING (отдельный GCP project / префикс)
# =============================================================================
# NODE_ENV=production
# GCP_PROJECT_ID=staging-xxxxx
# LIVE_TRADING_ENABLED=false
# ENGINE_TRADING_MODE=paper
# Secrets: Secret Manager staging-binance-key, staging-binance-secret

# =============================================================================
# PRODUCTION
# =============================================================================
# LIVE_TRADING_ENABLED=false   # true ТОЛЬКО после docs/PHASE7 pre-live checklist
# ENGINE_TRADING_MODE=paper    # live только вместе с ключами + ack
# Secrets только через GCP Secret Manager / Cloud Run secret mount

# =============================================================================
# FIREBASE (engine Admin SDK)
# =============================================================================
# GOOGLE_APPLICATION_CREDENTIALS=/path/to.json

# =============================================================================
# WEB BUILD (Vite) — публичные ключи, не секреты Binance
# =============================================================================
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=

# =============================================================================
# CI (GitHub Actions) — placeholder для сборки web без реального проекта
# =============================================================================
# VITE_FIREBASE_API_KEY=ci
# VITE_FIREBASE_AUTH_DOMAIN=localhost
# VITE_FIREBASE_PROJECT_ID=ci

# =============================================================================
# FUNCTIONS BOOTSTRAP (один раз)
# =============================================================================
# BOOTSTRAP_ADMIN_SECRET=  # только в Firebase Functions config / secrets
