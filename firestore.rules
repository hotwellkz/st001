rules_version = '2';

/**
 * Строгие правила:
 * - Клиент НЕ пишет в engineState, orders, fills, idempotencyKeys, auditLog.
 * - Критичные действия только через Cloud Functions (Admin SDK).
 * - Чтение чувствительных коллекций: admin claim ИЛИ свой userId.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function ownUserId() {
      return request.auth.uid;
    }

    // Профиль: читает/пишет только владелец поля uid (создание профиля — Functions onCreate)
    match /users/{uid} {
      allow read: if isSignedIn() && (uid == ownUserId() || isAdmin());
      allow write: if false;
    }

    // Настройки стратегии: чтение своих; запись только admin (или через Function)
    match /strategyConfigs/{id} {
      allow read: if isSignedIn() && (resource.data.userId == ownUserId() || isAdmin());
      allow write: if false;
    }

    match /symbolsUniverse/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /orders/{id} {
      allow read: if isSignedIn() && (resource.data.userId == ownUserId() || isAdmin());
      allow write: if false;
    }

    match /fills/{id} {
      allow read: if isSignedIn() && (resource.data.userId == ownUserId() || isAdmin());
      allow write: if false;
    }

    match /positions/{id} {
      allow read: if isSignedIn() && (resource.data.userId == ownUserId() || isAdmin());
      allow write: if false;
    }

    match /engineState/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /logs/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /alerts/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /auditLog/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /backtestResults/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /idempotencyKeys/{id} {
      allow read, write: if false;
    }

    match /locks/{id} {
      allow read, write: if false;
    }
  }
}
