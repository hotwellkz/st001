{
  "name": "crypto-trading-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:api": "pnpm --filter @app/api dev",
    "dev:engine": "pnpm --filter @app/engine dev",
    "dev:backtester": "pnpm --filter @app/backtester dev",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm --filter @pkg/binance test && pnpm --filter @pkg/storage test && pnpm --filter @pkg/strategy test && pnpm --filter @pkg/testing test && pnpm --filter @app/engine test && pnpm --filter @app/backtester test",
    "test:quick": "pnpm --filter @pkg/testing run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
